{
  "name": "sendora",
  "version": "1.0.0",
  "description": "Free peer-to-peer file transfers in your browser.",
  "packageManager": "pnpm@10.18.0",
  "author": "Sendora",
  "license": "BSD-3-Clause",
  "homepage": "https://github.com/techorigins-stack/sendora",
  "scripts": {
    "dev": "next",
    "dev:full": "docker compose up redis coturn -d && COTURN_ENABLED=true REDIS_URL=redis://localhost:6379 next",
    "build": "next build",
    "build:standalone": "NEXT_OUTPUT_STANDALONE=true next build && cp -r public .next/standalone/ && cp -r .next/static .next/standalone/.next/",
    "start": "next start",
    "start:peerjs": "./bin/peerjs.js",
    "lint:check": "eslint 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "docker:restart": "docker compose restart",
    "docker:clean": "docker compose down -v --rmi all",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "type:check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "pnpm build && playwright test",
    "ci": "pnpm lint:check && pnpm format:check && pnpm type:check && pnpm test && pnpm build && pnpm test:e2e && pnpm docker:build"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "@tailwindcss/postcss": "^4.1.11",
    "@tanstack/react-query": "^5.90.12",
    "autoprefixer": "^10.4.23",
    "debug": "^4.4.3",
    "express": "^5.2.1",
    "fflate": "^0.8.3",
    "hash-wasm": "^4.12.0",
    "highlight.js": "^11.11.1",
    "ioredis": "^5.11.0",
    "next": "~15.5.18",
    "next-themes": "^0.4.6",
    "next-view-transitions": "^0.3.5",
    "nodemon": "^3.1.11",
    "peer": "^1.0.2",
    "peerjs": "^1.5.5",
    "postcss": "^8.5.15",
    "react": "~19.2.3",
    "react-device-detect": "^2.2.3",
    "react-dom": "~19.2.3",
    "react-icons": "^5.6.0",
    "react-qr-code": "^2.0.18",
    "streamsaver": "^2.0.6",
    "tailwindcss": "^4.1.11",
    "web-streams-polyfill": "^4.1.0",
    "webrtcsupport": "^2.2.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^1.3.0",
    "@eslint/js": "^9.32.0",
    "@playwright/test": "^1.54.2",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/debug": "^4.1.12",
    "@types/node": "^22.19.3",
    "@types/react": "^19.2.7",
    "@types/wicg-file-system-access": "^2023.10.7",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.32.0",
    "eslint-config-next": "~15.5.11",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.2.7",
    "playwright": "^1.60.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^3.2.4"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "git add"
    ]
  }
}
